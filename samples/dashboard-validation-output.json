        "priority": "high",
        "role": "Project Manager",
        "openproject_reference": "Project Management",
        "traceability": "S-P01",
        "steps": ["Login as PM", "Open project dashboard"],
        "expectedResult": "Open, overdue, and closed counts match backend"
      },
      {
        "id": "TC-002",
        "title": "Apply invalid status filter",
        "type": "negative",
        "priority": "medium",
        "role": "Project Manager",
        "openproject_reference": "Project Management",
        "traceability": "S-N01",
        "steps": ["Select invalid filter combination"],
        "expectedResult": "Empty state shown without error"
      },
      {
        "id": "TC-003",
        "title": "Overdue work packages highlighted",
        "type": "status",
        "priority": "high",
        "role": "Project Manager",
        "openproject_reference": "Project Management",
        "traceability": "S-ST01",
        "steps": ["View overdue section"],
        "expectedResult": "Overdue items shown in red"
      },
      {
        "id": "TC-004",
        "title": "Filter dashboard by Open status",
        "type": "dashboard",
        "priority": "medium",
        "role": "Project Manager",
        "openproject_reference": "Project Management",
        "traceability": "S-D01",
        "steps": ["Apply Open filter"],
        "expectedResult": "Only open work packages counted"
      },
      {
        "id": "TC-005",
        "title": "Dashboard chart reloads after filter change",
        "type": "regression",
        "priority": "low",
        "role": "Project Manager",
        "openproject_reference": "Project Management",
        "traceability": "S-REG01",
