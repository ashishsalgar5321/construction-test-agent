        "expectedResult": "Chart updates without layout break"
      }
    ]
  },
  "testData": {
    "dashboardMetrics": { "open": 12, "overdue": 3, "closed": 45 }
  },
  "skeleton": {
    "code": "test('dashboard', async ({ page }) => { await page.goto('/projects/1'); await expect(page.locator('.dashboard-metrics')).toBeVisible(); });"
  },
  "coverage": { "coverageScore": 85, "summary": "Dashboard counts, filters, and overdue display covered." }
