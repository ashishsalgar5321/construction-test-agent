{
  "requirement": "The project manager dashboard should show correct counts of open, overdue, and closed work packages with proper filters.",
  "parsed": {
    "summary": "Dashboard metrics and filters for work package counts",
    "workflow": "Dashboard Validation",
    "openproject_module": "Project Management"
  },
  "scenarios": {
    "positive": [{ "id": "S-P01", "title": "Dashboard shows correct totals", "description": "Counts match data" }],
    "negative": [{ "id": "S-N01", "title": "Invalid filter shows empty", "description": "No crash on bad filter" }],
    "role_based": [{ "id": "S-R01", "title": "PM sees full dashboard", "role": "Project Manager" }],
    "status": [{ "id": "S-ST01", "title": "Overdue highlighted", "status": "Overdue" }],
    "dashboard": [{ "id": "S-D01", "title": "Filter by status Open", "description": "Filtered count" }],
    "regression": [{ "id": "S-REG01", "title": "Chart loads after filter", "description": "UI stable" }]
  },
  "testCases": {
