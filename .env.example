# Copy to .env.local and fill in your keys (never commit .env.local)

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Clerk Dashboard: see docs/CLERK-AUTH-SETUP.md
# - Turn OFF email verification at sign-up (email + password only, no code email)
# - Enable Google OAuth + "Always show account selector" for shared devices
# - Password reset lives under Manage account → Security
GROQ_API_KEY=your_groq_api_key

# History & Reports — required on Vercel (Storage → Postgres / Neon). Optional locally (uses data/ folder).
# POSTGRES_URL=postgres://...
# DATABASE_URL=postgres://...  # also accepted (Neon / Vercel integration)
# Optional — enables dashboard OpenProject module links to open your own instance
# NEXT_PUBLIC_OPENPROJECT_URL=https://your-openproject-instance.com
# Optional — defaults to llama-3.1-8b-instant
# GROQ_MODEL=llama-3.1-8b-instant
